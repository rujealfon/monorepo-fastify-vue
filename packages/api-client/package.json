{
  "name": "@monorepo-fastify-vue/api-client",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsc --watch",
    "build": "rm -rf dist && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "types:generate": "openapi-typescript ../../apps/api/openapi.json -o src/schema.d.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@monorepo-fastify-vue/eslint-config": "workspace:^",
    "eslint": "^10.6.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.9.3"
  }
}
