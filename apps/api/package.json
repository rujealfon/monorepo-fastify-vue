{
  "name": "@monorepo-fastify-vue/api",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "imports": {
    "#api/*": {
      "development": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    "./schema": "./src/db/schema/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --conditions=development --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "openapi:generate": "tsx --env-file=.env scripts/generate-openapi-spec.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.3.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^7.0.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@monorepo-fastify-vue/eslint-config": "workspace:^",
    "@types/node": "^25.9.5",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
