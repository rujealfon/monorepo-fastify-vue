{
  "name": "monorepo-fastify-vue",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run -r --parallel --aggregate-output dev",
    "build": "pnpm run -r build",
    "build:vercel": "pnpm build && pnpm db:migrate",
    "start": "pnpm --filter @monorepo-fastify-vue/api start",
    "test": "pnpm run -r --parallel test",
    "lint": "pnpm run -r --parallel lint",
    "lint:fix": "pnpm run -r --parallel lint:fix",
    "prepare": "husky",
    "openapi:generate": "pnpm --filter @monorepo-fastify-vue/api openapi:generate",
    "types:generate": "pnpm --filter @monorepo-fastify-vue/api-client types:generate",
    "api-client:generate": "pnpm openapi:generate && pnpm types:generate",
    "api-client:check": "pnpm api-client:generate && git diff --exit-code -- apps/api/openapi.json packages/api-client/src/schema.d.ts",
    "db:generate": "pnpm --filter @monorepo-fastify-vue/api db:generate",
    "db:migrate": "pnpm --filter @monorepo-fastify-vue/api db:migrate",
    "db:seed": "pnpm --filter @monorepo-fastify-vue/api db:seed",
    "db:studio": "pnpm --filter @monorepo-fastify-vue/api db:studio",
    "docker:start": "docker compose start",
    "docker:stop": "docker compose stop",
    "docker:restart": "docker compose restart",
    "docker:rebuild": "docker compose up --build -d web api",
    "docker:rebuild:all": "docker compose up --build -d",
    "docker:db:migrate": "docker compose exec api pnpm --filter @monorepo-fastify-vue/api db:migrate"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "apps/api/**/*.{js,mjs,ts,json}": "pnpm --filter @monorepo-fastify-vue/api exec eslint --fix",
    "apps/web/**/*.{js,mjs,ts,vue,json,css,html}": "pnpm --filter @monorepo-fastify-vue/web exec eslint --fix",
    "packages/api-client/**/*.{js,mjs,ts,json}": "pnpm --filter @monorepo-fastify-vue/api-client exec eslint --fix",
    "packages/eslint-config/**/*.{js,mjs,ts,json}": "pnpm --filter @monorepo-fastify-vue/eslint-config exec eslint --fix"
  }
}
